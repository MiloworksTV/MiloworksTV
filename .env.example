# Copy to .env and fill in. .env is gitignored.
#
# This .env at the engine repo root powers the bundled examples
# (e.g. examples/milo). Each project you create with `miloworks init`
# also gets its own .env.example.

# xAI / Grok Imagine — https://x.ai/api
XAI_API_KEY=

# fal.ai (optional, for the Kling backend) — https://fal.ai/dashboard/keys
# FALAI_API_KEY=

# Copy to .env (gitignored) and fill in.
#
# When you `miloworks --project examples/milo serve` from the repo
# root, the engine looks here first, then falls back to the engine
# root's .env. So if you've already configured .env at the repo
# root, you can leave this empty.

XAI_API_KEY=
